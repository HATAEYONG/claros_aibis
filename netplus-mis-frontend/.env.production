# Production Environment Variables for NetPlus MIS-AI Dashboard Frontend
# AWS Lightsail 배포용 설정

# API Configuration
# nginx 프록시를 사용하므로 빈 문자열로 설정 (상대 경로 사용)
VITE_API_URL=

# API Timeout (ms)
VITE_API_TIMEOUT=30000

# LLM Configuration (Backend에서 처리하지만 프론트엔드에서도 참조 가능)
VITE_OPENAI_API_KEY=sk-your-openai-api-key

# Application Configuration
VITE_APP_NAME=NetPlus MIS-AI Dashboard
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_SWAGGER=true
VITE_ENABLE_DEBUG=false
