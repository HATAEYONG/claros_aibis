[Unit]
Description=Claros MIS-AI Dashboard Gunicorn Daemon
After=network.target

[Service]
Type=notify
User=www-data
Group=www-data
RuntimeDirectory=claros-mis
WorkingDirectory=/var/www/claros-mis/backend
ExecStart=/var/www/claros-mis/venv/bin/gunicorn \
    --config python:/config/gunicorn.py \
    config.wsgi:application
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
