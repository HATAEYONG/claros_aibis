# Production Environment Variables for NetPlus MIS-AI Dashboard
# AWS Lightsail 배포용 설정

# ==========================================
# Django Configuration
# ==========================================
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=.amazonaws.com,.lightsail.aws,localhost,127.0.0.1

# ==========================================
# Database Configuration
# ==========================================
# SQLite (기본 - 개발용)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# PostgreSQL (운영 추천 - AWS Lightsail PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=netplus_mis
DB_USER=netplus_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ==========================================
# CORS Configuration
# ==========================================
# 운영 환경에서는 프론트엔드 도메인만 허용
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://your-ip-address

# ==========================================
# Static/Media Files
# ==========================================
STATIC_ROOT=/var/www/netplus-mis/static
MEDIA_ROOT=/var/www/netplus-mis/media

# ==========================================
# Security Settings
# ==========================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ==========================================
# LLM Configuration (OpenAI)
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-4-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# ==========================================
# ERP Configuration (EMAX ERP)
# ==========================================
ERP_HOST=your-erp-host.com
ERP_PORT=3306
ERP_DB_NAME=YH
ERP_USER=erp_user
ERP_PASSWORD=your-erp-password

# ==========================================
# Celery Configuration
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_AUTOSCALE_MIN=2
CELERY_WORKER_AUTOSCALE_MAX=8

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ELASTICSEARCH_URL=http://localhost:9200
ENVIRONMENT=production

# ==========================================
# Metrics Configuration
# ==========================================
ENABLE_METRICS=True
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ==========================================
# Adaptive Batch Configuration
# ==========================================
ADAPTIVE_BATCH_ENABLED=True
BATCH_SIZE_MIN=100
BATCH_SIZE_MAX=5000
NETWORK_CHECK_INTERVAL=60
