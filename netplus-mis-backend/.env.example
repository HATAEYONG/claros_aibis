# ============================================================================
# Netplus MIS-AI Dashboard Environment Variables
# ============================================================================

# ============================================================================
# Django Settings
# ============================================================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-secret-key-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

# ============================================================================
# Database Configuration
# ============================================================================
# DB_TYPE Options:
#   - local  : 로컬 PostgreSQL (기본)
#   - prod   : 운영 YH PostgreSQL
#   - sqlite : SQLite (개발/테스트용)
DB_TYPE=local

# Local PostgreSQL Settings (DB_TYPE=local 일 때 사용)
DB_NAME=netplus_mis
DB_USER=netplus_user
DB_PASSWORD=netplus_password
DB_HOST=localhost
DB_PORT=5432

# Production YH PostgreSQL Settings (DB_TYPE=prod 일 때 사용)
# DB_NAME=YH
# DB_USER=yh
# DB_PASSWORD=db!@yh#$1!
# DB_HOST=133.186.214.219
# DB_PORT=27455

# ============================================================================
# CORS Settings
# ============================================================================
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# MS SQL ERP Configuration (YH ERP 연동용)
# ============================================================================
MSSQL_HOST=133.186.214.219
MSSQL_PORT=27455
MSSQL_USER=yh
MSSQL_PASSWORD=
MSSQL_DATABASE=YH
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_ENCRYPT=no
MSSQL_TRUST_SERVER_CERTIFICATE=yes
MSSQL_CONNECTION_TIMEOUT=30

# ============================================================================
# Sync Configuration
# ============================================================================
SYNC_BATCH_SIZE=1000
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=60
SYNC_TIMEOUT=300

# Table Sync Intervals (in seconds)
SYNC_SCHEDULE_REALTIME=900      # 15 minutes
SYNC_SCHEDULE_HOURLY=3600       # 1 hour
SYNC_SCHEDULE_DAILY=86400       # 1 day
SYNC_SCHEDULE_WEEKLY=604800     # 1 week
SYNC_SCHEDULE_MONTHLY=2592000   # 1 month

# ============================================================================
# KPI Configuration
# ============================================================================
KPI_CACHE_ENABLED=True
KPI_CACHE_TTL=300
KPI_CALCULATION_TIMEOUT=60

# ============================================================================
# AI Prediction Configuration
# ============================================================================
AI_PREDICTION_ENABLED=True
AI_MODEL_PATH=models/
AI_PREDICTION_CACHE_TTL=3600

# ============================================================================
# Celery Worker Configuration
# ============================================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_AUTOSCALE_MIN=2
CELERY_WORKER_AUTOSCALE_MAX=8

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=text                # 'json' or 'text'
ELASTICSEARCH_URL=http://localhost:9200

# ============================================================================
# Prometheus Metrics
# ============================================================================
ENABLE_METRICS=True

# ============================================================================
# Adaptive Batch Configuration
# ============================================================================
ADAPTIVE_BATCH_ENABLED=True
BATCH_SIZE_MIN=100
BATCH_SIZE_MAX=5000
NETWORK_CHECK_INTERVAL=60

# ============================================================================
# Production Security Settings (DEBUG=False 일 때 적용)
# ============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ============================================================================
# Django 5.1 New Settings
# ============================================================================

# ============================================================================
# Redis Cache Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
USE_HIREDIS=False

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATELIMIT_ENABLE=True

# ============================================================================
# API Versioning Configuration
# ============================================================================
API_VERSION=v1

# ============================================================================
# WebSocket Settings
# ============================================================================
CHANNEL_LAYERS=redis
CHANNEL_HOST=localhost
CHANNEL_PORT=6379
